# Example env file (do NOT commit secrets)

PORT=3000
NODE_ENV=production

# MongoDB URL used by Prisma
DATABASE_URL=mongodb://mongo:27017/willdb

# JWT secret (change to a long random string)
JWT_SECRET=your_jwt_secret_here

# App URL used in emails
APP_URL=http://localhost:3000

# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Set to false when the frontend is deployed as a separate service
SERVE_STATIC_FRONTEND=true

# Folder to serve when SERVE_STATIC_FRONTEND=true
FRONTEND_DIR=teste-front

# SMTP (email) settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=supersecretpassword
SMTP_FROM=you@example.com
# Set to false only in local environments with TLS interception/self-signed certs
SMTP_TLS_REJECT_UNAUTHORIZED=true

# MFA by email
MFA_ENABLED=false
MFA_CHALLENGE_SECRET=change_this_mfa_secret
MFA_CODE_TTL_MINUTES=10
MFA_CODE_LENGTH=6
